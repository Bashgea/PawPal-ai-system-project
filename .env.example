# .env.example — copy to .env and edit before running PawPal+
# All variables are optional; defaults shown here.

# ── Ollama ─────────────────────────────────────────────────────────────────────
# Host where Ollama is listening.  PawPal+ normalises 'localhost' to '127.0.0.1'
# automatically to avoid the Windows IPv6 delay (~2 s per attempt).
OLLAMA_HOST=http://localhost:11434

# Model to use for planning.  Must be pulled first: ollama pull llama3.1:8b
PAWPAL_MODEL=llama3.1:8b

# Total timeout (seconds) covering connect + full model generation.
# llama3.1:8b cold-load from disk can take 60-120 s on spinning-disk hardware.
# Raise to 180+ if you regularly hit timeouts after the health check passes.
MODEL_TIMEOUT_S=120

# Transport-level retries after a timeout or transient server error.
MODEL_MAX_RETRIES=2

# Maximum AI repair iterations before falling back to the deterministic schedule.
MAX_REPAIR_ITERS=2

# ── Features ───────────────────────────────────────────────────────────────────
ENABLE_AI=true

# RAG is optional.  Set to false if you have no knowledge/ corpus or want faster
# responses.  The AI plan still works without it.
ENABLE_RAG=true
KNOWLEDGE_DIR=./knowledge

# ── Storage & logging ──────────────────────────────────────────────────────────
PAWPAL_DB=./pawpal.json
LOG_LEVEL=INFO
LOG_FILE=./pawpal.log
